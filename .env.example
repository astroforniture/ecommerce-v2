# Copia in `.env` e `.env.local` (Vite legge entrambi; riavvia `npm run dev` dopo ogni modifica).

# --- Supabase ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe (chiave PUBBLICA test, inizia con pk_test_) ---
# Dashboard Stripe → Developers → API keys → Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_incolla_qui_la_tua_chiave

# La SECRET key (sk_test_…) NON va nel frontend.
# Configurala come secret Supabase per la Edge Function:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce
